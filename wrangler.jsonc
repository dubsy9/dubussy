{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dubussy",
  "main": "src/index.js", 
  "compatibility_date": "2024-04-01", 
  "assets": {
    "directory": "./", 
    "binding": "ASSETS",
    "run_worker_first": true 
  },
  "observability": {
    "enabled": true
  },
  "environment": {
    "variables": {
      "DEFAULT_MODEL": "devstral-small-2:24b-cloud",
      "OLLAMA_API_URL": "https://api.ollama.com/v1"
    },
    "secrets": {
      "DISCORD_APPLICATION_ID": "",
      "DISCORD_BOT_TOKEN": "",
      "DISCORD_PUBLIC_KEY": "",
      "OLLAMA_TOKEN": ""
    }
  }
}
