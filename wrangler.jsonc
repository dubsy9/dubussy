{
  "name": "dubussy",
  "main": "src/index.js",
  "compatibility_date": "2024-04-01",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "DEFAULT_MODEL": "devstral-small-2:24b-cloud",
    "OLLAMA_API_URL": "https://ollama.com"
  },
  "kv_namespaces": [
    {
      "binding": "SITE_DATA",
      "id": "0d556e8125a94e9dbb8b385afe7b29ee"
    }
  ]
}